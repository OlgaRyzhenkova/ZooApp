<Window x:Class="ZooApp.Views.AccountingUnitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Облікова одиниця"
        Height="360" Width="480"
        MinHeight="320" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        Closing="Window_Closing">

    <DockPanel Margin="16">

        <Border DockPanel.Dock="Top" Background="#1565C0" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,16">
            <TextBlock x:Name="WindowTitle" Text="Облікова одиниця"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="✅  Зберегти та закрити"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="160" Margin="0,0,8,0"
                    Click="SaveBtn_Click"/>
            <Button Content="✖  Скасувати та закрити"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="160"
                    Click="CancelBtn_Click"/>
        </StackPanel>

        <StackPanel>

            <TextBlock Text="Дата прибуття"
                       Style="{StaticResource FieldLabel}"/>
            <DatePicker x:Name="ArrivalDatePicker"
                        Style="{StaticResource ValidatedDatePicker}"
                        Margin="0,0,0,12"
                        SelectedDateChanged="ArrivalDatePicker_SelectedDateChanged"/>

            <TextBlock Text="Вартість утримання (грн)"
                       Style="{StaticResource FieldLabel}"/>
            <TextBox Style="{StaticResource ValidatedTextBox}"
                     Text="{Binding KeepingCost,
                            ValidatesOnDataErrors=True,
                            ValidatesOnExceptions=True,
                            UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16"/>

            <Border BorderBrush="#BDBDBD" BorderThickness="1"
                    CornerRadius="4" Padding="12" Background="White">
                <StackPanel>
                    <TextBlock Text="🐾  Тварина" FontWeight="Bold"
                               FontSize="13" Foreground="#1565C0"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="AnimalDisplayText"
                               Text="(тварину не вказано)"
                               Foreground="#757575"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Button Content="✏️  Редагувати дані тварини"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Click="EditAnimalBtn_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </DockPanel>
</Window>