<Window x:Class="ZooApp.Views.AnimalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Дані тварини"
        Height="420" Width="440"
        MinHeight="380" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        Closing="Window_Closing">

    <DockPanel Margin="16">

        <Border DockPanel.Dock="Top" Background="#2E7D32" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,16">
            <TextBlock Text="🐾  Тварина"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="✅  Зберегти та закрити"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="160" Margin="0,0,8,0"
                    Click="SaveBtn_Click"/>
            <Button Content="✖  Скасувати та закрити"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="160"
                    Click="CancelBtn_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Вид (напр. Лев, Тигр, Дельфін)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource ValidatedTextBox}"
                         Text="{Binding Species,
                                ValidatesOnDataErrors=True,
                                ValidatesOnExceptions=True,
                                UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Кличка"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource ValidatedTextBox}"
                         Text="{Binding Name,
                                ValidatesOnDataErrors=True,
                                ValidatesOnExceptions=True,
                                UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Країна походження"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource ValidatedTextBox}"
                         Text="{Binding CountryOfOrigin,
                                ValidatesOnDataErrors=True,
                                ValidatesOnExceptions=True,
                                UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Дата народження"
                           Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="BirthDatePicker"
                            Style="{StaticResource ValidatedDatePicker}"
                            Margin="0,0,0,12"
                            SelectedDateChanged="BirthDatePicker_SelectedDateChanged"/>

                <Border BorderBrush="#A5D6A7" BorderThickness="1"
                        CornerRadius="4" Padding="10"
                        Background="#E8F5E9" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="Попередній перегляд (ToString):"
                                   FontWeight="Bold" FontSize="11"
                                   Foreground="#2E7D32" Margin="0,0,0,4"/>
                        <TextBlock x:Name="PreviewText"
                                   Foreground="#1B5E20"
                                   TextWrapping="Wrap" FontSize="11"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>